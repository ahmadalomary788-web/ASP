<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] – دبرها</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="~/css/style.css">
    @RenderSection("Styles", required: false)
</head>
<body>

    <!-- ========== NAVBAR ========== -->
    <nav class="navbar">
        <a href="@Url.Action("Index", "Home")" class="nav-logo">
            <div class="nav-logo-name">دَبر<span>ها</span></div>
        </a>
        <ul class="nav-links">
            <li><a href="@Url.Action("Index", "Home")">الرئيسية</a></li>
            <li><a href="#">معدات يدوية</a></li>
            <li><a href="#">مركبات ثقيلة</a></li>
        </ul>
        <div class="nav-search">
            <i class="fas fa-search"></i>
            <input type="text" placeholder="ابحث...">
        </div>
        <div class="nav-actions">
            <a href="#" class="btn-add-listing">➕ أضف إعلان</a>
            <a href="@Url.Action("Login", "Account")" class="btn-login" id="loginNavBtn">تسجيل الدخول</a>
        </div>
    </nav>

    <!-- ========== BODY ========== -->
    <main>
        @RenderBody()
    </main>

    <!-- ========== FOOTER ========== -->
    <footer>
        <div class="footer-inner">
            <div class="footer-col">
                <h4>دبرها</h4>
                <ul class="footer-links">
                    <li><a href="@Url.Action("About", "Home")">عن المنصة</a></li>
                    <li><a href="#">شروط الاستخدام</a></li>
                    <li><a href="#">سياسة الخصوصية</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>تواصل معنا</h4>
                <div class="social-icons">
                    <a href="#"><i class="fab fa-facebook"></i></a>
                    <a href="#"><i class="fab fa-instagram"></i></a>
                    <a href="#"><i class="fab fa-whatsapp"></i></a>
                </div>
            </div>
            <div class="footer-col">
                <h4>روابط سريعة</h4>
                <ul class="footer-links">
                    <li><a href="#">معدات يدوية</a></li>
                    <li><a href="#">مركبات ثقيلة</a></li>
                    <li><a href="#">أضف إعلانك</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">© 2025 دبّرها – جميع الحقوق محفوظة</div>
    </footer>

    <script src="~/js/common.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>