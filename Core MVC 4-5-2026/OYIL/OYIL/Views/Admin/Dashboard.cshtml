@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Dashboard";
}




@{
    string[] names = { "Ghosoun", "Ahmad", "Anwar", "Zaina", "Heba" };
}


@{
    int j = 1;

    var products = new[]
    {
        new { Name="Mouse", Price=50.0, QuantityStock=0 },
        new { Name="Keyboard", Price=100.0, QuantityStock=2 },
        new { Name="Laptop", Price=800.0, QuantityStock=5 },
        new { Name="Headphones", Price=500.0, QuantityStock=12 }
    };
}


@{
    var rooms = new[]
    {
        new
        {
            Title = "Single Room",
            Description = "A cozy room designed for one guest.",
            ImageUrl = "/images/single.jpg"
        },

        new
        {
            Title = "Double Room",
            Description = "Comfortable room suitable for two guests.",
            ImageUrl = "/images/double.jpg"
        },

        new
        {
            Title = "Triple Room",
            Description = "Spacious room for families or groups.",
            ImageUrl = "/images/triple.jpg"
        }
    };
}

<div class="container mt-4">


    <h2 class="mb-3">Names Table</h2>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Firstname</th>
            </tr>
        </thead>

        <tbody>
            @foreach (string name in names)
            {
                <tr>
                    <td>@name</td>
                </tr>
            }
        </tbody>
    </table>

    <hr />



    <h2 class="mb-3">Products Table</h2>

    <table class="table table-bordered table-hover">

        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Price</th>
                <th>Quantity Stock</th>
                <th>Status</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var i in products)
            {
                <tr>

                    <td>@j</td>
                    <td>@i.Name</td>
                    <td>$@i.Price</td>
                    <td>@i.QuantityStock</td>

                    <td>

                        @if (i.QuantityStock > 5)
                        {
                            <span class="text-success fw-bold">
                                In Stock
                            </span>
                        }

                        else if (i.QuantityStock > 0)
                        {
                            <span class="text-warning fw-bold">
                                Low Stock
                            </span>
                        }

                        else
                        {
                            <span class="text-danger fw-bold">
                                Out of Stock
                            </span>
                        }

                    </td>

                </tr>

                j++;
            }

        </tbody>

    </table>

    <hr />



    <h2 class="mb-4">Rooms Cards</h2>

    <div class="row">

        @foreach (var room in rooms)
        {
            <div class="col-md-4 mb-4">

                <div class="card h-100 shadow border-0"
                     style="background-color:#ead2b7;">

                    <img src="@room.ImageUrl"
                         class="card-img-top"
                         style="height:250px; object-fit:cover;" />

                    <div class="card-body d-flex flex-column">

                        <h4 class="card-title">
                            @room.Title
                        </h4>

                        <p class="card-text">
                            @room.Description
                        </p>

                        <a href="#"
                               class="btn btn-primary mt-auto">
                            View Room
                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

</div>